{
  "name": "@rekurt/ohlcv-vue",
  "version": "0.1.0",
  "description": "Vue 3 wrapper for @rekurt/ohlcv-core — <OHLCVChart> component and useOHLCVChart composable.",
  "keywords": ["ohlcv", "candlestick", "chart", "vue", "vue3", "trading", "canvas"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rekurt/ohlcv-vue.git"
  },
  "bugs": {
    "url": "https://github.com/rekurt/ohlcv-vue/issues"
  },
  "homepage": "https://github.com/rekurt/ohlcv-vue#readme",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "workspaces": ["example"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src example/src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p example/tsconfig.json",
    "dev:example": "npm run dev -w example",
    "build:example": "npm run build -w example",
    "update:core": "node scripts/update-core.mjs"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "peerDependencies": {
    "@rekurt/ohlcv-core": "^0.1.0",
    "vue": ">=3.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rekurt/ohlcv-core": "file:./vendor/rekurt-ohlcv-core.tgz",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0"
  }
}
